rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Connection test path
    match /test/connection {
      allow read: if true;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'koheinkhantko51@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidTaurusAccountCode(value) {
      return value is string && value.matches('^TRS-[A-Z0-9]{7}$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function currentUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function immutableUserFieldsValid() {
      return incoming().uid == existing().uid
        && incoming().role == existing().role
        && incoming().email == existing().email
        && incoming().credits == existing().credits
        && incoming().tier == existing().tier
        && (!('taurusId' in existing()) || incoming().taurusId == existing().taurusId)
        && (!('taurusNumber' in existing()) || incoming().taurusNumber == existing().taurusNumber)
        && (!('taurusCoinBalance' in existing()) || incoming().taurusCoinBalance == existing().taurusCoinBalance)
        && (!('songCreditBalance' in existing()) || incoming().songCreditBalance == existing().songCreditBalance)
        && (!('apiAccessEnabled' in existing()) || incoming().apiAccessEnabled == existing().apiAccessEnabled);
    }

    function isOwnerUsageUpdate(userId) {
      return isOwner(userId)
        && immutableUserFieldsValid()
        && incoming().diff(existing()).affectedKeys().hasOnly([
          'displayName',
          'dailyGenerationCount',
          'lastGenerationDate',
          'pendingPayment',
          'requestedTier',
          'paymentStatus',
          'paymentProofUrl',
          'paymentProofPath',
          'paymentProofName',
          'paymentSubmittedAt',
          'paymentRejectedAt',
          'paymentRejectReason',
          'songsUsedThisWeek',
          'songsUsedThisMonth',
          'lastRefillDate',
          'lastMonthlyRefillDate',
          'weeklyLimit',
          'monthlyLimit',
          'points',
          'lastPointGrantDate',
          'totalPointsEarned',
          'taurusId',
          'taurusNumber',
          'taurusCoinBalance',
          'songCreditBalance',
          'apiAccessEnabled',
          'challengeRegistered',
          'challengeRegisteredAt',
          'challengeGenerateLimit',
          'challengeGenerateUsed',
          'challengeEntryId'
        ])
        && (!('taurusId' in incoming()) || isValidTaurusAccountCode(incoming().taurusId))
        && (!('taurusNumber' in incoming()) || incoming().taurusNumber == incoming().taurusId)
        && (!('taurusCoinBalance' in incoming()) || ('taurusCoinBalance' in existing()) || incoming().taurusCoinBalance == 0)
        && (!('songCreditBalance' in incoming()) || ('songCreditBalance' in existing()) || incoming().songCreditBalance == 0)
        && (!('apiAccessEnabled' in incoming()) || ('apiAccessEnabled' in existing()) || incoming().apiAccessEnabled == true);
    }

    function isOwnerChatBanUpdate(userId) {
      return isOwner(userId)
        && immutableUserFieldsValid()
        && incoming().diff(existing()).affectedKeys().hasOnly([
          'chatBannedUntil',
          'chatBanReason',
          'chatBannedAt',
          'chatLastViolation',
          'chatLastViolationAt',
          'chatBanCount',
          'chatViolationCount'
        ])
        && (!('chatBannedUntil' in incoming())
          || incoming().chatBannedUntil == null
          || incoming().chatBannedUntil is timestamp);
    }

    function isChatAllowed() {
      return isAdmin()
        || !('chatBannedUntil' in currentUserData())
        || currentUserData().chatBannedUntil == null
        || currentUserData().chatBannedUntil <= request.time;
    }

    function isCleanChatText() {
      return !(incoming().text.matches('(?i).*(fuck|shit|bitch|asshole|motherfucker|cunt).*')
        || incoming().text.matches('.*(လီး|စောက်|မအေ|လိုး|ဖာ|ဖင်).*'));
    }

    function isValidChatText() {
      return incoming().text is string
        && incoming().text.size() > 0
        && incoming().text.size() <= 4000
        && isCleanChatText();
    }

    function isUserChatMessage() {
      return incoming().keys().hasOnly([
          'user',
          'text',
          'userId',
          'timestamp',
          'isSongShare',
          'songId',
          'songTitle',
          'songUrl',
          'songMimeType'
        ])
        && incoming().userId == request.auth.uid
        && incoming().user is string
        && incoming().user.size() > 0
        && incoming().user.size() <= 80
        && incoming().timestamp == request.time
        && isValidChatText()
        && (!('isSongShare' in incoming()) || incoming().isSongShare == true)
        && (!('songId' in incoming()) || isValidId(incoming().songId))
        && (!('songTitle' in incoming()) || (incoming().songTitle is string && incoming().songTitle.size() <= 160))
        && (!('songUrl' in incoming()) || (incoming().songUrl is string && incoming().songUrl.size() < 1000))
        && (!('songMimeType' in incoming()) || (incoming().songMimeType is string && incoming().songMimeType.size() <= 80));
    }

    function isAiChatMessage() {
      return incoming().keys().hasOnly(['user', 'text', 'userId', 'timestamp', 'isAi', 'createdBy'])
        && incoming().user == 'Taurus AI'
        && incoming().userId == 'taurus-ai'
        && incoming().isAi == true
        && incoming().createdBy == request.auth.uid
        && incoming().timestamp == request.time
        && isValidChatText();
    }

    function isValidPublicSong() {
      return incoming().keys().hasOnly([
          'userId',
          'sourceSongId',
          'title',
          'prompt',
          'audioUrl',
          'mimeType',
          'lyrics',
          'authorName',
          'authorPhotoUrl',
          'coverTheme',
          'visibility',
          'createdAt',
          'publishedAt'
        ])
        && incoming().userId == request.auth.uid
        && isValidId(incoming().sourceSongId)
        && incoming().title is string
        && incoming().title.size() > 0
        && incoming().title.size() <= 160
        && incoming().prompt is string
        && incoming().prompt.size() <= 1500
        && incoming().audioUrl is string
        && incoming().audioUrl.size() < 1000
        && incoming().mimeType is string
        && incoming().mimeType.size() <= 80
        && incoming().lyrics is string
        && incoming().lyrics.size() <= 6000
        && incoming().authorName is string
        && incoming().authorName.size() > 0
        && incoming().authorName.size() <= 80
        && (!('authorPhotoUrl' in incoming()) || incoming().authorPhotoUrl == null || (incoming().authorPhotoUrl is string && incoming().authorPhotoUrl.size() < 1000))
        && incoming().coverTheme is string
        && incoming().coverTheme.size() <= 40
        && incoming().visibility == 'public'
        && incoming().createdAt == request.time
        && incoming().publishedAt == request.time;
    }

    function isValidChallengeRegistration(userId) {
      return incoming().keys().hasOnly([
          'challengeId',
          'userId',
          'email',
          'displayName',
          'taurusId',
          'generateLimit',
          'generateUsed',
          'registeredAt',
          'updatedAt'
        ])
        && incoming().userId == userId
        && incoming().email == request.auth.token.email
        && incoming().challengeId == 'taurus-music-studio-challenge-2026-05'
        && incoming().displayName is string
        && incoming().displayName.size() > 0
        && incoming().displayName.size() <= 80
        && incoming().generateLimit is number
        && incoming().generateLimit >= 5
        && incoming().generateLimit <= 5
        && incoming().generateUsed is number
        && incoming().generateUsed >= 0
        && incoming().generateUsed <= incoming().generateLimit
        && (!('registeredAt' in incoming()) || incoming().registeredAt == request.time || incoming().registeredAt == existing().registeredAt)
        && (!('updatedAt' in incoming()) || incoming().updatedAt == request.time);
    }

    function isValidChallengeEntry() {
      return incoming().keys().hasOnly([
          'id',
          'challengeId',
          'userId',
          'sourceSongId',
          'title',
          'prompt',
          'audioUrl',
          'mimeType',
          'lyrics',
          'authorName',
          'authorEmail',
          'createdAt',
          'publishedAt',
          'likeCount',
          'commentCount',
          'saveCount',
          'score',
          'visibility',
          'originalOnly',
          'updatedAt'
        ])
        && incoming().challengeId == 'taurus-music-studio-challenge-2026-05'
        && incoming().userId == request.auth.uid
        && incoming().id == request.auth.uid
        && isValidId(incoming().sourceSongId)
        && incoming().title is string
        && incoming().title.size() > 0
        && incoming().title.size() <= 160
        && incoming().prompt is string
        && incoming().prompt.size() <= 1500
        && incoming().audioUrl is string
        && incoming().audioUrl.size() < 1000
        && incoming().mimeType is string
        && incoming().mimeType.size() <= 80
        && incoming().lyrics is string
        && incoming().lyrics.size() <= 6000
        && incoming().authorName is string
        && incoming().authorName.size() > 0
        && incoming().authorName.size() <= 80
        && (!('authorEmail' in incoming()) || incoming().authorEmail == request.auth.token.email)
        && incoming().likeCount == 0
        && incoming().commentCount == 0
        && incoming().saveCount == 0
        && incoming().score == 0
        && incoming().visibility == 'public'
        && incoming().originalOnly == true
        && incoming().createdAt == request.time
        && incoming().publishedAt == request.time;
    }

    function isChallengeCounterUpdate() {
      return incoming().diff(existing()).affectedKeys().hasOnly(['likeCount', 'commentCount', 'saveCount', 'score', 'updatedAt'])
        && incoming().userId == existing().userId
        && incoming().sourceSongId == existing().sourceSongId
        && incoming().challengeId == existing().challengeId
        && incoming().title == existing().title
        && incoming().prompt == existing().prompt
        && incoming().audioUrl == existing().audioUrl
        && incoming().mimeType == existing().mimeType
        && incoming().lyrics == existing().lyrics
        && incoming().authorName == existing().authorName
        && incoming().visibility == existing().visibility
        && incoming().originalOnly == existing().originalOnly
        && incoming().likeCount is number
        && incoming().commentCount is number
        && incoming().saveCount is number
        && incoming().score is number
        && incoming().likeCount >= 0
        && incoming().commentCount >= 0
        && incoming().saveCount >= 0
        && incoming().score >= 0
        && incoming().updatedAt == request.time;
    }

    function isValidChallengeReaction(userId) {
      return incoming().keys().hasOnly(['userId', 'liked', 'saved', 'updatedAt'])
        && userId == request.auth.uid
        && incoming().userId == request.auth.uid
        && incoming().liked is bool
        && incoming().saved is bool
        && incoming().updatedAt == request.time;
    }

    function isValidChallengeComment(entryId) {
      return incoming().keys().hasOnly(['id', 'entryId', 'userId', 'authorName', 'text', 'createdAt'])
        && incoming().entryId == entryId
        && incoming().userId == request.auth.uid
        && incoming().authorName is string
        && incoming().authorName.size() > 0
        && incoming().authorName.size() <= 80
        && incoming().text is string
        && incoming().text.size() > 0
        && incoming().text.size() <= 280
        && incoming().createdAt == request.time;
    }

    function hasValidApiScopes() {
      return incoming().scopes is list
        && incoming().scopes.size() > 0
        && incoming().scopes.size() <= 3
        && incoming().scopes.hasOnly(['song.generate', 'voice.use', 'lyrics.generate']);
    }

    function isDeveloperApiKeyCreate(userId) {
      return isOwner(userId)
        && incoming().keys().hasOnly([
          'ownerId',
          'name',
          'prefix',
          'keyHash',
          'scopes',
          'status',
          'usageCount',
          'rateLimitPerMinute',
          'createdAt',
          'lastUsedAt'
        ])
        && incoming().ownerId == request.auth.uid
        && incoming().name is string
        && incoming().name.size() > 0
        && incoming().name.size() <= 80
        && incoming().prefix is string
        && incoming().prefix.matches('^taurus_sk_[a-f0-9]{8}$')
        && incoming().keyHash is string
        && incoming().keyHash.matches('^[a-f0-9]{64}$')
        && hasValidApiScopes()
        && incoming().status == 'active'
        && incoming().usageCount == 0
        && incoming().rateLimitPerMinute is int
        && incoming().rateLimitPerMinute > 0
        && incoming().rateLimitPerMinute <= 60
        && incoming().createdAt == request.time
        && incoming().lastUsedAt == null;
    }

    function isDeveloperApiKeyUpdate(userId) {
      return isOwner(userId)
        && incoming().ownerId == existing().ownerId
        && incoming().prefix == existing().prefix
        && incoming().keyHash == existing().keyHash
        && incoming().scopes == existing().scopes
        && incoming().usageCount == existing().usageCount
        && incoming().rateLimitPerMinute == existing().rateLimitPerMinute
        && incoming().createdAt == existing().createdAt
        && incoming().lastUsedAt == existing().lastUsedAt
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'status', 'revokedAt'])
        && incoming().name is string
        && incoming().name.size() > 0
        && incoming().name.size() <= 80
        && (incoming().status == 'active' || incoming().status == 'revoked')
        && (!('revokedAt' in incoming()) || incoming().revokedAt == existing().revokedAt || incoming().revokedAt == request.time);
    }

    function isValidVoiceProfile(userId, profileId) {
      return incoming().keys().hasOnly([
          'id',
          'userId',
          'name',
          'sampleUrl',
          'storagePath',
          'contentType',
          'consent',
          'consentText',
          'createdAt'
        ])
        && incoming().id == profileId
        && incoming().userId == request.auth.uid
        && incoming().name is string
        && incoming().name.size() > 0
        && incoming().name.size() <= 80
        && incoming().sampleUrl is string
        && incoming().sampleUrl.size() < 1000
        && incoming().storagePath is string
        && incoming().storagePath.matches('^users/' + userId + '/voice-profiles/' + profileId + '/.*')
        && incoming().contentType is string
        && incoming().contentType.matches('audio/.*')
        && incoming().consent == true
        && incoming().consentText is string
        && incoming().consentText.size() <= 500
        && incoming().createdAt == request.time;
    }

    // User Profile
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isSignedIn() && isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId 
        && incoming().keys().hasOnly([
          'uid',
          'email',
          'displayName',
          'taurusId',
          'taurusNumber',
          'taurusCoinBalance',
          'songCreditBalance',
          'apiAccessEnabled',
          'dailyGenerationCount',
          'lastGenerationDate',
          'credits',
          'points',
          'lastPointGrantDate',
          'totalPointsEarned',
          'tier',
          'role',
          'weeklyLimit',
          'songsUsedThisWeek',
          'lastRefillDate',
          'monthlyLimit',
          'songsUsedThisMonth',
          'lastMonthlyRefillDate',
          'chatViolationCount',
          'chatBanCount'
        ])
        && incoming().uid == request.auth.uid
        && incoming().email == request.auth.token.email
        && (!('taurusId' in incoming()) || isValidTaurusAccountCode(incoming().taurusId))
        && (!('taurusNumber' in incoming()) || incoming().taurusNumber == incoming().taurusId)
        && (!('taurusCoinBalance' in incoming()) || incoming().taurusCoinBalance == 0)
        && (!('songCreditBalance' in incoming()) || incoming().songCreditBalance == 0)
        && (!('apiAccessEnabled' in incoming()) || incoming().apiAccessEnabled == true)
        && incoming().dailyGenerationCount == 0
        && incoming().credits == 0
        && incoming().points == 60
        && incoming().totalPointsEarned == 60
        && incoming().tier == 'free'
        && incoming().weeklyLimit == 60
        && incoming().songsUsedThisWeek == 0
        && incoming().monthlyLimit == 60
        && incoming().songsUsedThisMonth == 0
        && (incoming().role == 'user' || (incoming().role == 'admin' && request.auth.token.email == 'koheinkhantko51@gmail.com'));
      allow update: if isAdmin() || isOwnerUsageUpdate(userId) || isOwnerChatBanUpdate(userId);
    }

    // Developer API keys
    match /users/{userId}/apiKeys/{apiKeyId} {
      allow list, get: if isOwner(userId) || isAdmin();
      allow create: if isDeveloperApiKeyCreate(userId);
      allow update: if isAdmin() || isDeveloperApiKeyUpdate(userId);
      allow delete: if isOwner(userId) || isAdmin();
    }

    // User-owned voice profiles
    match /users/{userId}/voiceProfiles/{profileId} {
      allow list, get: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId)
        && isValidId(profileId)
        && isValidVoiceProfile(userId, profileId);
      allow delete: if isOwner(userId) || isAdmin();
    }

    // Chat messages
    match /chatMessages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && isChatAllowed()
        && (isUserChatMessage() || isAiChatMessage());
      allow update, delete: if isAdmin();
    }

    // Public Music World feed
    match /publicSongs/{publicSongId} {
      allow read: if true;
      allow create: if isSignedIn()
        && isChatAllowed()
        && isValidId(publicSongId)
        && isValidPublicSong();
      allow update: if isSignedIn()
        && isOwner(existing().userId)
        && isValidPublicSong();
      allow delete: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
    }

    // Taurus Studio Challenge
    match /challengeRegistrations/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create, update: if isOwner(userId)
        && isChatAllowed()
        && isValidChallengeRegistration(userId);
      allow delete: if isAdmin();
    }

    match /challengeEntries/{entryId} {
      allow read: if true;
      allow create: if isSignedIn()
        && isChatAllowed()
        && entryId == request.auth.uid
        && isValidChallengeEntry();
      allow update: if isSignedIn()
        && isChatAllowed()
        && isChallengeCounterUpdate();
      allow delete: if isAdmin();

      match /reactions/{userId} {
        allow read: if isSignedIn();
        allow create, update: if isOwner(userId)
          && isChatAllowed()
          && isValidChallengeReaction(userId);
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn()
          && isChatAllowed()
          && isValidChallengeComment(entryId);
        allow update, delete: if isAdmin();
      }
    }

    // Presence
    match /presence/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && request.auth.uid == userId
        && incoming().keys().hasOnly(['userId', 'displayName', 'email', 'photoURL', 'lastSeen'])
        && incoming().userId == request.auth.uid
        && incoming().lastSeen == request.time;
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }
    
    // Songs subcollection
    match /users/{userId}/songs/{songId} {
      allow list: if isOwner(userId);
      allow get: if isOwner(userId) && isValidId(songId);
      allow create: if isOwner(userId)
        && isChatAllowed()
        && isValidId(songId)
        && incoming().userId == request.auth.uid
        && incoming().audioUrl is string
        && incoming().audioUrl.size() < 1000
        && incoming().createdAt == request.time;
      allow delete: if isOwner(userId);
    }
  }
}
