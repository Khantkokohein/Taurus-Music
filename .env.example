# GEMINI_API_KEY: Required by server API routes for Gemini and Lyria calls.
# Set this as a Vercel environment variable for production.
# For local development, put the real key in .env.local and never commit it.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
