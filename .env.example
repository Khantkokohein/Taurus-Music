# GEMINI_API_KEY: Required by server API routes for Gemini and Lyria calls.
# Set this as a Vercel environment variable for production.
# For local development, put the real key in .env.local and never commit it.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Google Cloud / Firebase project used by Taurus Music.
GOOGLE_CLOUD_PROJECT="taurus-calling"
GOOGLE_CLOUD_QUOTA_PROJECT="taurus-calling"
FIREBASE_API_KEY="MY_FIREBASE_WEB_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# TaurusPay auto payment integration. Keep real values in Vercel env only.
TAURUSPAY_BASE_URL="https://tauruspay.site"
TAURUSPAY_API_KEY="MY_TAURUSPAY_API_KEY"
TAURUSPAY_WEBHOOK_SECRET="MY_TAURUSPAY_WEBHOOK_SECRET"
TAURUSPAY_USDT_ADDRESS="MY_TAURUSPAY_RECEIVE_WALLET"
TAURUSPAY_CALLBACK_URL="https://taurus-music.vercel.app/api/tauruspay-webhook"

# Firebase Admin service account JSON or base64 JSON for Vercel server routes.
FIREBASE_SERVICE_ACCOUNT_KEY="MY_FIREBASE_SERVICE_ACCOUNT_JSON_OR_BASE64"
FIREBASE_SERVICE_ACCOUNT_JSON="MY_FIREBASE_SERVICE_ACCOUNT_JSON"
